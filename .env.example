# 前端（Vercel 环境变量）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Crawler（GitHub Secrets，不要放前端）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 服务端专用：独立 PostgreSQL 岗位库连接串（示例值，不要提交真实账号、主机或密码）
JOBS_DATABASE_URL=postgresql://jobs_user:replace-me@db.example.invalid:5432/jobradar_jobs?sslmode=require
# 可信 CA PEM；支持真实换行或环境变量中常见的 \n 转义。缺失时 jobs 连接会拒绝启动
JOBS_DATABASE_SSL_CA=
# 默认使用 URL 主机名；仅当前 IP 端点可用 hostaddr + 此证书 SAN，DNS 主机必须与证书 SAN 一致
JOBS_DATABASE_TLS_SERVERNAME=

# 实时搜索扩源；默认最多查询 22 个 Greenhouse / Lever 官方 ATS 源
LIVE_ATS_SOURCE_LIMIT=22

# 百度千帆 Web Search；免费额度用完或不希望消耗额度时设为 true
BAIDU_QIANFAN_SEARCH_DISABLED=false
BAIDU_QIANFAN_API_KEY=
